<script>
const track=document.getElementById('track');
const dotsEl=document.getElementById('dots');
const total=10;
let cur=0;

for(let i=0;i<total;i++){
  const d=document.createElement('div');
  d.className='dot'+(i===0?' active':'');
  d.onclick=()=>go(i);
  dotsEl.appendChild(d);
}

function go(n){
  cur=n;
  track.style.transform='translateX(-'+cur*100+'%)';
  document.querySelectorAll('.dot').forEach((d,i)=>d.className='dot'+(i===cur?' active':''));
}

document.getElementById('next').onclick=()=>go((cur+1)%total);
document.getElementById('prev').onclick=()=>go((cur-1+total)%total);

let auto=setInterval(()=>go((cur+1)%total),3500);
track.addEventListener('mouseenter',()=>clearInterval(auto));
track.addEventListener('mouseleave',()=>{auto=setInterval(()=>go((cur+1)%total),3500);});

let sX=0;
track.addEventListener('touchstart',e=>sX=e.touches[0].clientX,{passive:true});
track.addEventListener('touchend',e=>{const d=sX-e.changedTouches[0].clientX;if(Math.abs(d)>40)go(d>0?(cur+1)%total:(cur-1+total)%total);},{passive:true});

let c=1247;
setInterval(()=>{if(Math.random()>.6)c+=Math.floor(Math.random()*2)+1;document.getElementById('cnt').textContent=c.toLocaleString('pt-BR');},5000);
</script>
</body>
</html>
