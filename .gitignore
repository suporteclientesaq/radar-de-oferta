<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Radar de Oferta 🔎 — Achadinhos com até 80% OFF</title>
<meta name="description" content="Grupo gratuito de ofertas e achadinhos da Shopee, Amazon, Magalu e Mercado Livre. Descontos de até 80% OFF todo dia!">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#0a0a0a;color:#fff;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:0.6}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}
@keyframes ctapulse{0%,100%{box-shadow:0 0 0 0 rgba(37,211,102,0.5)}50%{box-shadow:0 0 0 14px rgba(37,211,102,0)}}

.wrap{max-width:480px;margin:0 auto;background:#0a0a0a;min-height:100vh;}

/* HERO */
.hero{background:#c80000;padding:1.3rem 1rem 1.6rem;text-align:center;position:relative;overflow:hidden;}
.live-pill{display:inline-flex;align-items:center;gap:5px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.3);padding:3px 12px;border-radius:20px;font-size:11px;margin-bottom:10px;}
.live-dot{width:7px;height:7px;background:#ff4444;border-radius:50%;animation:blink 1s infinite;}
.badge-free{display:inline-block;background:#FFD700;color:#000;font-size:11px;font-weight:800;padding:4px 14px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;animation:blink 2s infinite;}
.hero h1{font-size:2.2rem;font-weight:900;line-height:1.05;text-transform:uppercase;text-shadow:2px 2px 0 rgba(0,0,0,0.4);}
.hero h1 em{color:#FFD700;font-style:normal;}
.hero-sub{font-size:.95rem;opacity:.9;margin:8px 0 14px;}
.stats{display:flex;justify-content:center;gap:20px;background:rgba(0,0,0,0.35);border-radius:10px;padding:10px 16px;margin-bottom:16px;}
.stat-n{display:block;font-size:1.5rem;font-weight:900;color:#FFD700;}
.stat-l{font-size:10px;opacity:.8;text-transform:uppercase;letter-spacing:.5px;}
.cta-btn{display:block;background:#25D366;color:#fff;font-size:1.05rem;font-weight:900;text-align:center;padding:15px;border-radius:12px;border:none;cursor:pointer;width:100%;text-transform:uppercase;animation:ctapulse 2.2s infinite;text-decoration:none;letter-spacing:.5px;}
.cta-btn:hover{background:#1da850;}
.arrow{text-align:center;font-size:1.4rem;margin:10px 0 0;animation:bounce 1.5s infinite;}

/* STORES */
.stores{background:#111;padding:10px 16px;display:flex;justify-content:center;gap:16px;flex-wrap:wrap;border-bottom:1px solid #1a1a1a;}
.store-chip{display:flex;align-items:center;gap:5px;font-size:12px;color:#aaa;}

/* URGENCY */
.urgency-wrap{background:#111;padding:4px 0 0;}
.urgency{background:#1a0000;border:1px solid #880000;border-radius:10px;margin:12px;padding:12px 14px;text-align:center;}
.urgency p{font-size:13px;color:#ff7777;margin-bottom:7px;}
.prog{height:8px;background:#330000;border-radius:4px;overflow:hidden;}
.prog-fill{height:100%;width:73%;background:linear-gradient(90deg,#ff6600,#ff0000);border-radius:4px;}
.prog-label{font-size:10px;color:#555;margin-top:4px;display:block;}

/* SECTION HEADER */
.sec-head{text-align:center;padding:22px 16px 10px;background:#111;}
.sec-head h2{font-size:1.15rem;font-weight:900;text-transform:uppercase;}
.sec-head h2 em{color:#FFD700;font-style:normal;}
.sec-head p{font-size:12px;color:#666;margin-top:3px;}

/* CAROUSEL */
.carousel-wrap{background:#111;padding:0 0 16px;}
.carousel{position:relative;overflow:hidden;}
.carousel-track{display:flex;transition:transform .38s cubic-bezier(.4,0,.2,1);}
.carousel-slide{min-width:100%;padding:0 12px;}

.card{background:#1c1c1c;border-radius:12px;border:1px solid #2a2a2a;overflow:hidden;}
.card-img{width:100%;height:240px;object-fit:cover;display:block;background:#252525;}
.card-body{padding:12px;}
.card-badge{display:inline-block;font-size:10px;font-weight:800;padding:3px 9px;border-radius:4px;margin-bottom:8px;text-transform:uppercase;background:#ee4d2d;color:#fff;}
.card-name{font-size:14px;font-weight:700;color:#eee;line-height:1.35;margin-bottom:6px;}
.card-sold{font-size:11px;color:#888;margin-bottom:8px;}
.price-row{display:flex;align-items:baseline;gap:8px;margin-bottom:10px;flex-wrap:wrap;}
.price-old{font-size:12px;color:#555;text-decoration:line-through;}
.price-new{font-size:1.5rem;font-weight:900;color:#4ade80;}
.disc-tag{background:#ff0000;color:#fff;font-size:11px;font-weight:800;padding:3px 8px;border-radius:4px;}
.card-desc{font-size:12px;color:#888;line-height:1.5;margin-bottom:10px;}
.card-cta{display:block;background:#ff3030;color:#fff;text-align:center;padding:12px;font-size:13px;font-weight:800;border-radius:8px;cursor:pointer;border:none;width:100%;text-transform:uppercase;text-decoration:none;}
.card-cta:hover{background:#cc0000;}

.carousel-arrows{display:flex;justify-content:space-between;align-items:center;padding:12px 12px 0;}
.arr-btn{background:#2a2a2a;border:1px solid #333;color:#fff;width:38px;height:38px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.arr-btn:hover{background:#ff3030;}
.carousel-dots{display:flex;justify-content:center;gap:7px;}
.dot{width:8px;height:8px;border-radius:50%;background:#333;cursor:pointer;transition:all .2s;}
.dot.active{background:#ff3030;width:22px;border-radius:4px;}

/* SOCIAL PROOF */
.proof{background:#0f0f0f;padding:16px 12px;}
.proof-title{font-size:12px;font-weight:700;color:#444;text-transform:uppercase;letter-spacing:.5px;text-align:center;margin-bottom:12px;}
.proof-item{display:flex;align-items:flex-start;gap:10px;background:#181818;border-radius:8px;padding:10px;margin-bottom:8px;border-left:3px solid #25D366;}
.proof-av{width:36px;height:36px;border-radius:50%;background:#222;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.proof-t{font-size:12px;color:#ccc;line-height:1.45;}
.proof-t strong{color:#4ade80;}
.proof-time{font-size:10px;color:#444;margin-top:3px;}

/* FEATURES */
.feats{background:#0d0d0d;padding:16px 12px;}
.feats-title{font-size:12px;font-weight:700;color:#444;text-transform:uppercase;letter-spacing:.5px;text-align:center;margin-bottom:12px;}
.feat{display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;}
.feat-ico{width:38px;height:38px;border-radius:8px;background:#1a1a1a;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.feat h3{font-size:13px;font-weight:700;color:#fff;margin-bottom:2px;}
.feat p{font-size:12px;color:#666;line-height:1.4;}

/* BOTTOM CTA */
.btm-cta{background:#061a06;border-top:2px solid #25D366;padding:20px 14px;text-align:center;}
.btm-cta h2{font-size:1.3rem;font-weight:900;text-transform:uppercase;margin-bottom:6px;}
.btm-cta h2 em{color:#25D366;font-style:normal;}
.btm-cta p{font-size:13px;color:#555;margin-bottom:16px;}
.badge-green{display:inline-block;background:#FFD700;color:#000;font-size:11px;font-weight:800;padding:4px 14px;border-radius:20px;margin-bottom:12px;text-transform:uppercase;}

/* DISCLAIMER */
.disclaimer{background:#050505;padding:14px;text-align:center;border-top:1px solid #111;}
.disclaimer p{font-size:10px;color:#2a2a2a;line-height:1.6;}
</style>
</head>
